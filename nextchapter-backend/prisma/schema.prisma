generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @map("_id")
  name                 String
  email                String            @unique
  emailVerified        Boolean           @default(false)
  image                String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  sessions      Session[]
  accounts      Account[]
  members       Member[]
  teamMembers   TeamMember[]
  invitations   Invitation[]      @relation("InvitationInviter")
  transactions  Transaction[]
  jobApplications JobApplication[]
}

model Session {
  id                   String   @id @map("_id")
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?
  activeTeamId         String?

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @map("_id")
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Organization {
  id           String            @id @map("_id")
  name         String
  slug         String            @unique
  logo         String?
  metadata     Json?
  createdAt    DateTime          @default(now())

  members      Member[]
  invitations  Invitation[]
  teams        Team[]
  transactions Transaction[]
  jobApplications JobApplication[]
}

model Member {
  id             String       @id @map("_id")
  organizationId String
  userId         String
  role           String
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id             String       @id @map("_id")
  organizationId String
  email          String
  role           String?
  status         String       @default("pending")
  teamId         String?
  inviterId      String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
}

model Team {
  id             String       @id @map("_id")
  name           String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitations    Invitation[]
  teamMembers    TeamMember[]

  @@index([organizationId])
}

model TeamMember {
  id        String   @id @map("_id")
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Jwks {
  id         String   @id @map("_id")
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
  expiresAt  DateTime?
}

model Transaction {
  id                String                 @id @default(cuid()) @map("_id")
  organizationId    String
  userId            String
  rawText           String
  merchant          String
  amount            Float
  direction         TransactionDirection
  balanceAfter      Float?
  date              DateTime
  category          String?
  confidence        Float
  confidenceReasons String[]
  sourceFormat      String
  createdAt         DateTime               @default(now())

  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([organizationId, createdAt])
  @@index([userId])
}

enum TransactionDirection {
  DEBIT
  CREDIT
}

model JobApplication {
  id                String       @id @default(cuid()) @map("_id")
  organizationId    String
  userId            String
  rawText           String
  companyName       String
  roles             String
  stipend           String?
  location          String?
  duration          String?
  eligibility       String?
  deadline          String?
  applicationLink   String?
  status            String       @default("Not Applied")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId])
}
